{
  "name": "agbench",
  "version": "1.0.7",
  "description": "AGBench desktop workspace",
  "main": "./out/main/index.js",
  "author": "Chris Izatt",
  "license": "Apache-2.0",
  "homepage": "https://github.com/boggspa/AGBench",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boggspa/AGBench.git"
  },
  "bugs": {
    "url": "https://github.com/boggspa/AGBench/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "security:supply-chain": "node scripts/security-supply-chain-check.cjs",
    "security:signatures": "npm audit signatures",
    "security:audit": "npm audit --omit=dev --audit-level=critical",
    "security:deps": "npm run security:supply-chain && npm run security:signatures && npm run security:audit",
    "ci": "npm run security:deps && npm run typecheck && npm run test && npm run smoke:node-pty",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "smoke:node-pty": "node scripts/smoke-node-pty.cjs",
    "smoke:gemini-mcp-args": "node scripts/smoke-gemini-mcp-args.cjs",
    "smoke:gemini-api-sdk": "node scripts/smoke-gemini-api-sdk.cjs",
    "smoke:package": "node scripts/smoke-packaged-electron.cjs",
    "smoke:bridge-daemon": "npm run prebuild:bridge-daemon && node scripts/smoke-bridge-daemon-roundtrip.cjs",
    "prebuild:bridge-daemon": "node scripts/build-bridge-daemon.cjs",
    "test:swift:bridge": "cd swift/AgbenchBridge && swift test",
    "validate:release": "node scripts/validate-release.cjs",
    "build:unpack": "npm run prebuild:bridge-daemon && npm run build && electron-builder --dir && node scripts/smoke-packaged-electron.cjs dist",
    "build:debug:mac": "npm run prebuild:bridge-daemon && npm run build && electron-builder --dir --config electron-builder.debug.yml && node scripts/smoke-packaged-electron.cjs dist-debug",
    "build:debug:mac:notarized": "npm run prebuild:bridge-daemon && npm run build && electron-builder --dir --config electron-builder.debug.yml -c.mac.notarize=true && node scripts/smoke-packaged-electron.cjs dist-debug",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run prebuild:bridge-daemon && npm run build && electron-builder --mac",
    "build:mac:notarized": "npm run prebuild:bridge-daemon && npm run build && electron-builder --mac -c.mac.notarize=true && node scripts/smoke-packaged-electron.cjs dist",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.140",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@google/genai": "^2.4.0",
    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.5"
  }
}
