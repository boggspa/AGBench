<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      RELEASE-ONLY entitlements variant.

      This file mirrors `GuiGeminiCompanion.entitlements` (the Debug /
      TestFlight variant) except for the `aps-environment` key, which is
      flipped from `development` to `production`. The same .p8 APNs auth
      key works for both Apple gateways — the env field on the
      `BridgeActionPayload.registerApnsToken` action tells the Mac which
      side of Apple's infrastructure to target.

      `project.yml` wires this file into the GuiGeminiCompanion target's
      Release configuration. Debug keeps `GuiGeminiCompanion.entitlements`
      so local device runs continue using the sandbox APNs gateway.
    -->
    <key>aps-environment</key>
    <string>production</string>

    <!--
      App Groups — mirrored from the Debug variant. Reserved for future
      Live Activity widget / share extension / shared Keychain access
      between the main app and any extensions. Group identifier matches
      what `BridgeProductConfiguration.guiGemini.appGroupIdentifier`
      declares on the desktop side.
    -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.example.AGBench</string>
    </array>
</dict>
</plist>
